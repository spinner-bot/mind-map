{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh",
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build & Run",
            "type": "shell",
            "command": "${workspaceFolder}/build.sh && ${workspaceFolder}/mind_map.exe",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm -rf obj/*.obj mind_map.exe",
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}
